{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://alluring-nurturing-production.up.railway.app/api/$1"
    },
    {
      "src": "/ws",
      "dest": "https://alluring-nurturing-production.up.railway.app/ws"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
