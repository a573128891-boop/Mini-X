{
  "build": {
    "command": "go mod download && CGO_ENABLED=0 GOOS=linux go build -o server ./cmd/server",
    "watchPatterns": ["backend/**"]
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "healthCheck": {
    "path": "/api/health"
  },
  "port": 3001
}
